## Implementing operations

Implement the generated API traits and pass your implementation to the generated router:

```rust
use std::sync::Arc;
use async_trait::async_trait;
use tokio::net::TcpListener;

#[derive(Clone)]
struct ApiImpl;

impl AsRef<ApiImpl> for ApiImpl {
    fn as_ref(&self) -> &ApiImpl {
        self
    }
}

impl {{{externCrateName}}}::apis::ErrorHandler for ApiImpl {}

// Implement the generated traits under {{{externCrateName}}}::apis here.

#[tokio::main]
async fn main() {
    let app = {{{externCrateName}}}::server::new(ApiImpl);
    let listener = TcpListener::bind("0.0.0.0:1337").await.unwrap();
    axum::serve(listener, app).await.unwrap();
}
```

